APP_NAME="Inte.Team CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/London
APP_URL=http://localhost:8090
APP_PORT=8090
VITE_PORT=5190
PMA_PORT=8091
MAIL_UI_PORT=8029
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ──────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=inteteam_cms
DB_USERNAME=cms
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# ─── Cache / Queue / Session ───────────────────────────────────────────────
BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

# ─── Mail (Mailpit in dev) ─────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@cms.inte.team"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Filesystem ────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
CMS_MEDIA_DISK=local

# S3 (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Vite ──────────────────────────────────────────────────────────────────
VITE_APP_ENV="${APP_ENV}"

# ─── CMS-specific ──────────────────────────────────────────────────────────
# Platform root domain — used to extract tenant slug from subdomain
CMS_DOMAIN=cms.inte.team

# ─── SSO (Phase 3 — leave blank for now) ───────────────────────────────────
SSO_ENABLED=false
# SSO_URL=https://sso.inte.team
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=https://cms.inte.team/auth/sso/callback
